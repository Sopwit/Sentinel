{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_DISABLE_FIND_PACKAGE_WrapVulkanHeaders": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_DISABLE_FIND_PACKAGE_WrapVulkanHeaders": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Release with debug info",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/relwithdebinfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_DISABLE_FIND_PACKAGE_WrapVulkanHeaders": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "package-ready",
      "displayName": "Package-ready release",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/package-ready",
      "cacheVariables": {
        "SENTINEL_BUILD_NUMBER": "0"
      }
    },
    {
      "name": "tests",
      "displayName": "Tests",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/tests"
    },
    {
      "name": "no-ccache",
      "displayName": "Debug without ccache wrapper",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/no-ccache",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "/usr/bin/c++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "package-ready",
      "configurePreset": "package-ready",
      "targets": [
        "sentinel-desktop"
      ]
    },
    {
      "name": "tests",
      "configurePreset": "tests"
    },
    {
      "name": "no-ccache",
      "configurePreset": "no-ccache"
    }
  ],
  "testPresets": [
    {
      "name": "tests",
      "configurePreset": "tests",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "no-ccache",
      "configurePreset": "no-ccache",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
